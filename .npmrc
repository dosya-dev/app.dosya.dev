# Pintura is a commercial package served from a private registry.
# The public npmjs.org package is only a stub, so @pqina must be scoped here.
# NPM_TOKEN is provided as an environment variable (locally + in Cloudflare build settings);
# no secret is stored in this file.
@pqina:registry=https://npm.pqina.nl/
//npm.pqina.nl/:_authToken=${NPM_TOKEN}
